{
  "name": "worldstriders-charlist",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test:ui": "playwright test",
    "test:e2e": "playwright test tests/ui-smoke.spec.ts",
    "test:visual": "playwright test tests/ui-visual.spec.ts",
    "test:visual:update": "playwright test tests/ui-visual.spec.ts --update-snapshots",
    "test:capture": "playwright test tests/ui-capture.spec.ts",
    "ci-check": "npm run lint && npm run typecheck && npm run build && npm run test:ui"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@types/js-yaml": "^4.0.9",
    "svelte-check": "^4.0.0",
    "typescript": "^5.5.4",
    "vite": "^6.3.0",
    "vite-plugin-singlefile": "^2.0.0"
  }
}
